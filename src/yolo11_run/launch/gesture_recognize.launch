<launch>
    <!-- 定义参数 -->
        <!-- 获取功能包路径 -->
    <arg name="pkg_path" default="$(find yolo11_run)" />
        <!-- 模型路径 -->
    <arg name="param_path" default="$(arg pkg_path)/model/gesture_result/best_pnnx.ncnn.param" />
    <arg name="bin_path" default="$(arg pkg_path)/model/gesture_result/best_pnnx.ncnn.bin" />
        <!-- 话题 -->
    <arg name="image_sub_topic" default="/usb_cam/image_rect_color/compressed" />
    <arg name="image_pub_topic" default="/yolo_image_gesture" />
    <arg name="labels_pub_topic" default="/yolo_labels_gesture" />
    
    <!-- 加载参数 -->
    <param name="param_path" value="$(arg param_path)" />
    <param name="bin_path" value="$(arg bin_path)" />
    <param name="image_sub_topic" value="$(arg image_sub_topic)" />
    <param name="image_pub_topic" value="$(arg image_pub_topic)" />
    <param name="labels_pub_topic" value="$(arg labels_pub_topic)" />

    <!-- 摄像头启动 -->
    <!-- <include file="$(find car_camera)/launch/camer_start.launch" /> -->
    <!-- yolo启动 -->
    <node pkg="yolo11_run" name="gesture_node" type="gesture_recognize" output="screen" >
    </node> 
    <!-- 启动底层 -->
    <node pkg="car_camera" name="gesture_drive_node" type="gesture_recognize_drive" output="screen"/>

    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find car_camera)/config/gesture.rviz" />
	
</launch>

