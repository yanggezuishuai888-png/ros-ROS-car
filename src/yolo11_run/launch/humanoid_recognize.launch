<launch>
    <!-- 获取功能包路径 -->
    <arg name="pkg_path" default="$(find yolo11_run)" />
    <!-- 模型路径 -->
    <arg name="param_path" default="$(arg pkg_path)/model/humanoid_result/humanoid_pnnx.py.ncnn.param" />
    <arg name="bin_path" default="$(arg pkg_path)/model/humanoid_result/humanoid_pnnx.py.ncnn.bin" />
    <!-- 话题 -->
    <arg name="image_sub_topic" default="/usb_cam/image_rect_color" />
    <arg name="image_pub_topic" default="/yolo_image_humanoid" />
    <arg name="labels_pub_topic" default="/yolo_labels_humanoid" />

    <!-- 加载（全局）-->
    <param name="image_sub_topic" value="$(arg image_sub_topic)" />
    <param name="image_pub_topic" value="$(arg image_pub_topic)" />
    <param name="labels_pub_topic" value="$(arg labels_pub_topic)" />
    <param name="image_width" value="640"/>

    <!-- 摄像头启动 -->
    <!-- <include file="$(find car_camera)/launch/camer_start.launch" /> -->
    <!-- yolo启动 -->
    <node pkg="yolo11_run" name="humanoid_recognize" type="humanoid_recognize" output="screen">
        <param name="param_path" value="$(arg param_path)" />
        <param name="bin_path" value="$(arg bin_path)" />
    </node> 
    <!-- 启动底层 -->
    <node pkg="car_camera" name="humanoid_tracking_drive" type="humanoid_tracking_drive" output="screen"/>

    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find car_camera)/config/start.rviz" />
	
</launch>

